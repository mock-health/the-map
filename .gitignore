# --- secrets ---
.tokens/
.env
.env.local
.env.*.local
*.pem
.secrets/
# HAR captures from auth flows can carry headers/nonces/session ids — keep
# them out by default. If a specific HAR is intentionally cited as evidence,
# scrub it and add an explicit allow-line below.
*.har

# --- python build artefacts ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
build/
dist/
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
CLAUDE.md

# --- render output (regenerable from ehrs/ + us-core/baseline.json) ---
reports/*/html/

# --- tooling state ---
.gstack/
.DS_Store

# --- internal planning notes (not part of the documentation product) ---
# Strategic plans for upcoming work (long-tail EHR ingest, mock.health
# integrations, etc.) live in PLAN.md and are intentionally local-only.
# The repo is the published map+drift artifact; planning notes aren't.
PLAN.md

# --- LLM disambiguation cache (regenerable; one Anthropic API call per row) ---
data/hospital-overrides/.cache/

# --- Bulk source-data indexes (regenerable from upstream CMS files) ---
# Built by tools.build_nppes_index / tools.build_pecos_index. Each one is
# 100s of MB and reconstructible deterministically from upstream data
# (NPPES Monthly Data Dissemination + PECOS PPEF). The downstream overlay
# files at data/hospital-overlays/ ARE committed — those are the product.
data/cms-nppes/orgs-*.jsonl
data/cms-nppes/fhir-endpoints-*.json
data/cms-pecos/enrollment-*.json

# --- Raw CMS source files fetched by tools.fetch_cms_* ---
# Multi-GB upstream archives (NPPES monthly zips, POS quarterly CSVs, PECOS
# PPEF extracts, NPD weekly NDJSON.zst). Regenerable from CMS via
# `make fetch-all-cms`; each dated subdir carries a .provenance.json with
# source URL + sha256.
/data/raw/

# --- Verification reports (regenerable from `make verify-overlay-refresh`) ---
# Timestamped per-run drift reports comparing committed overlays to a fresh
# rebuild. Useful as evidence in a PR description; not a long-term artifact.
/data/verification/

# --- IDE ---
.vscode/
.idea/
*.swp

# --- Git LFS ---
# tests/golden/production-fleet/ is tracked via Git LFS (see .gitattributes).
# Default `git clone` pulls pointer files only; run `git lfs pull` to fetch
# the 380MB of per-endpoint harvest evidence.
