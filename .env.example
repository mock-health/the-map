# --- The Map: contributor sandbox credentials ---
#
# Copy this file to `.env` and fill in the credentials for the EHR sandbox(es)
# you want to test against. Phase A (anonymous /metadata fetch) and Phase F
# (anonymous brands-bundle harvest) need ZERO credentials and run on a fresh
# clone with no .env at all.
#
# Each vendor has a public sandbox developer program — sign up to get the
# values below. See CONTRIBUTING.md for per-vendor links and walkthroughs.

# ============================================================================
# Epic on FHIR — https://fhir.epic.com/
# Backend Services (client_credentials) with RS384.
# ============================================================================
EPIC_NONPROD_CLIENT_ID=
EPIC_NONPROD_PRIVATE_KEY_PATH=        # path to RS384 private key PEM
EPIC_NONPROD_JWKS_KID=                # key id matching your published JWKS
EPIC_NONPROD_TOKEN_URL=https://fhir.epic.com/interconnect-fhir-oauth/oauth2/token
EPIC_NONPROD_FHIR_BASE=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4

# ============================================================================
# Cerner Code (Oracle Health) — https://code.cerner.com/
# RS256 backend services.
# ============================================================================
CERNER_NONPROD_CLIENT_ID=
CERNER_NONPROD_PRIVATE_KEY_PATH=
CERNER_NONPROD_JWKS_KID=
CERNER_NONPROD_TOKEN_URL=
CERNER_NONPROD_FHIR_BASE=

# ============================================================================
# MEDITECH Greenfield — https://developer.meditech.com/
# Standalone-launch SMART (auth_code, openid + fhirUser + launch/patient
# + offline_access + patient/*.read scopes; no `aud` parameter).
# ============================================================================
MEDITECH_NONPROD_CLIENT_ID=
MEDITECH_NONPROD_AUTHORIZE_URL=
MEDITECH_NONPROD_TOKEN_URL=
MEDITECH_NONPROD_FHIR_BASE=
MEDITECH_NONPROD_REDIRECT_URI=http://localhost:8765/callback

# ============================================================================
# Optional: HAPI cross-validation server (Phase 4)
# Run any HAPI image with the US Core 6.1.0 IG preloaded — see
# tools/hapi/docker-compose.example.yml for a vendor-neutral starting point.
# ============================================================================
HAPI_BASE=http://localhost:8080/fhir

# ============================================================================
# Optional: explicit env-file override.
# tools/_env.py loads (in priority order): $THE_MAP_ENV → ./<repo>/.env.
# Set THE_MAP_ENV to point at an alternative .env file if your dev layout
# keeps credentials outside the repo.
# ============================================================================
# THE_MAP_ENV=/path/to/your/.env
